generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Alimento {
  id           Int     @id @default(autoincrement())
  nome         String
  calorias     Float?
  proteina     Float?
  carboidrato  Float?
  gordura      Float?
}

enum Genero {
  M
  F
}

enum Alvo {
  BULKING
  CUTTING
}

model User {
  id                Int     @id @default(autoincrement())
  nome              String
  peso              Float
  altura            Float
  idade             Int
  genero            Genero?
  atividade         Int
  balancoCalorico   Int
  alvo              Alvo
  imc               Float
  tmb               Float
  tdee              Float
  calorias          Float
  proteinas         Float
  gorduras          Float
  carboidratos      Float
  caloriasDoDia     Float?
  proteinasDoDia    Float?
  gordurasDoDia     Float?
  carboidratosDoDia Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}