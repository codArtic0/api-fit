generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Alimento {
  id           Int     @id @default(autoincrement())
  nome         String
  calorias     Float?
  proteina     Float?
  carboidrato  Float?
  gordura      Float?
}

enum Sexo {
  M
  F
}

enum Alvo {
  BULKING
  CUTTING
}

model User {
  id               Int     @id @default(autoincrement())
  nome             String
  peso             Float?
  altura           Float?
  idade            Int?
  sexo             Sexo?
  atividade        Int?
  balancoCalorico  Int?
  alvo             Alvo?
  tmb              Float?
  tdee             Float?
  calorias         Float?
  proteinas        Float?
  gorduras         Float?
  carboidratos     Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}